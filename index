      </div>
    </section>
 
    <section>
      <div class="section-head"><h2>Certifications &amp; Courses</h2></div>
      <div class="cert-list" id="portfolio-certs"><!-- dynamic --></div>
    </section>
 
  </div>
</div>
 
 
<!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     TAB 3 — RESUME
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
<div id="tab-resume" class="tab-panel">
  <div class="print-wrap">
    <div class="print-actions">
      <button class="btn btn-fill" onclick="window.print()">🖨 Print / Save as PDF</button>
    </div>
    <div class="resume-sheet">
      <div class="r-header">
        <div class="r-name">Jason [Last Name]</div>
        <div class="r-title">Aspiring Software Developer</div>
        <div class="r-contact">
          <span>📧 your@email.com</span>
          <span>🔗 github.com/yourusername</span>
          <span>🌐 yourusername.github.io</span>
          <span>📍 City, State</span>
        </div>
      </div>
 
      <div class="r-section">
        <div class="r-section-title">About</div>
        <p class="r-about">Motivated career changer building foundational software development skills, with current focus on version control (Git/GitHub) and database fundamentals (SQL). Committed to continuous, hands-on learning through real projects.</p>
      </div>
 
      <div class="r-section">
        <div class="r-section-title">Skills</div>
        <div class="r-skills-row" id="resume-skills"><!-- dynamic --></div>
      </div>
 
      <div class="r-section">
        <div class="r-section-title">Projects</div>
        <div class="r-projects-list" id="resume-projects"><!-- dynamic --></div>
      </div>
 
      <div class="r-section">
        <div class="r-section-title">Experience</div>
        <div id="resume-experience"><!-- dynamic --></div>
      </div>
 
      <div class="r-section">
        <div class="r-section-title">Education</div>
        <div class="r-exp-top">
          <span class="r-role">Your Degree or Diploma</span>
          <span class="r-date">20XX</span>
        </div>
        <div class="r-company">School / Institution</div>
      </div>
 
      <div class="r-section">
        <div class="r-section-title">Certifications &amp; Courses</div>
        <div id="resume-certs"><!-- dynamic --></div>
      </div>
    </div>
  </div>
</div>
 
 
<!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     TAB 4 — LOG WORK
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
<div id="tab-logwork" class="tab-panel">
  <div class="log-page">
 
    <div class="log-header">
      <p class="mono" style="color:#a78bfa;margin-bottom:14px">// Log Work</p>
      <h1>Add to your portfolio</h1>
      <p>Log a project, skill, experience, or certification. It will appear across your Portfolio and Resume tabs automatically.</p>
    </div>
 
    <!-- AUTH GATE -->
    <div id="auth-gate" class="auth-gate">
      <h2>🔒 Enter your password</h2>
      <p>This keeps your portfolio editable only by you.</p>
      <div class="auth-row">
        <input type="password" id="auth-input" placeholder="Password" onkeydown="if(event.key==='Enter')checkAuth()"/>
        <button class="btn btn-purple" onclick="checkAuth()">Unlock</button>
      </div>
      <p class="auth-error" id="auth-error">Incorrect password. Try again.</p>
    </div>
 
    <!-- FORM (shown after auth) -->
    <div id="log-form-area" style="display:none">
 
      <!-- Type selector -->
      <div class="type-tabs">
        <button class="type-tab active" onclick="setType('project')">🗂 Project</button>
        <button class="type-tab"        onclick="setType('skill')">⚡ Skill</button>
        <button class="type-tab"        onclick="setType('experience')">💼 Experience</button>
        <button class="type-tab"        onclick="setType('certification')">🎓 Certification</button>
      </div>
 
      <!-- PROJECT form -->
      <div class="form-panel active" id="form-project">
        <div class="field"><label>Project name *</label><input type="text" id="proj-name" placeholder="e.g. SQL Dashboard"/></div>
        <div class="field"><label>Description *</label><textarea id="proj-desc" placeholder="What did you build? What did you learn?"></textarea></div>
        <div class="field"><label>GitHub URL</label><input type="text" id="proj-url" placeholder="https://github.com/you/repo"/></div>
        <div class="field"><label>Tags (comma-separated)</label><input type="text" id="proj-tags" placeholder="SQL, Python, DuckDB"/></div>
        <button class="btn btn-fill" onclick="saveEntry('project')">Save project</button>
      </div>
 
      <!-- SKILL form -->
      <div class="form-panel" id="form-skill">
        <div class="field"><label>Skill name *</label><input type="text" id="skill-name" placeholder="e.g. Python"/></div>
        <div class="field"><label>Status</label>
          <select id="skill-status">
            <option value="learning">Currently learning</option>
            <option value="proficient">Proficient</option>
          </select>
        </div>
        <button class="btn btn-fill" onclick="saveEntry('skill')">Save skill</button>
      </div>
 
      <!-- EXPERIENCE form -->
      <div class="form-panel" id="form-experience">
        <div class="field"><label>Job title *</label><input type="text" id="exp-role" placeholder="e.g. Data Analyst"/></div>
        <div class="field"><label>Company *</label><input type="text" id="exp-company" placeholder="e.g. Acme Corp"/></div>
        <div class="field-row">
          <div class="field"><label>Start date</label><input type="text" id="exp-start" placeholder="e.g. 2023"/></div>
          <div class="field"><label>End date</label><input type="text" id="exp-end" placeholder="e.g. Present"/></div>
        </div>
        <div class="field"><label>Description</label><textarea id="exp-desc" placeholder="What did you do? Key responsibilities or achievements."></textarea></div>
        <button class="btn btn-fill" onclick="saveEntry('experience')">Save experience</button>
      </div>
 
      <!-- CERTIFICATION form -->
      <div class="form-panel" id="form-certification">
        <div class="field"><label>Certification / Course name *</label><input type="text" id="cert-name" placeholder="e.g. freeCodeCamp — JavaScript Algorithms"/></div>
        <div class="field"><label>Issuer</label><input type="text" id="cert-issuer" placeholder="e.g. freeCodeCamp"/></div>
        <div class="field"><label>Year / Status</label><input type="text" id="cert-year" placeholder="e.g. 2025 or In progress"/></div>
        <button class="btn btn-fill" onclick="saveEntry('certification')">Save certification</button>
      </div>
 
      <!-- Saved entries list -->
      <div class="entries-section">
        <h3>Saved entries</h3>
        <div class="entry-list" id="entry-list"><!-- dynamic --></div>
      </div>
 
    </div><!-- /log-form-area -->
  </div>
</div>
 
 
<script>
/* ═══════════════════════════════════════
   SEED DATA — your starting content
   Edit these defaults here, or just use
   the Log Work form to add more.
═══════════════════════════════════════ */
const SEED = {
  projects: [
    { id:'seed-p1', type:'project', name:'Personal Portfolio Site', desc:'This site — a multi-tab portfolio built with plain HTML/CSS, hosted for free on GitHub Pages. First real project using Git to manage versions.', url:'https://github.com/yourusername/yourusername.github.io', tags:['HTML','CSS','GitHub Pages'] },
    { id:'seed-p2', type:'project', name:'SQL Practice Repo', desc:'A collection of SQL queries written while learning fundamentals: SELECT, WHERE, GROUP BY, JOINs. Uses DuckDB as a lightweight local database engine.', url:'https://github.com/yourusername/sql-practice', tags:['SQL','DuckDB','Databases'] },
  ],
  skills: [
    { id:'seed-s1', type:'skill', name:'Git',            status:'learning' },
    { id:'seed-s2', type:'skill', name:'SQL',            status:'learning' },
    { id:'seed-s3', type:'skill', name:'HTML / CSS',     status:'learning' },
    { id:'seed-s4', type:'skill', name:'GitHub Desktop', status:'proficient' },
    { id:'seed-s5', type:'skill', name:'DuckDB',         status:'proficient' },
  ],
  experience: [
    { id:'seed-e1', type:'experience', role:'Your Job Title', company:'Company Name', start:'2024', end:'Present', desc:'Describe what you do here in 1–2 sentences.' },
    { id:'seed-e2', type:'experience', role:'Previous Job Title', company:'Previous Company', start:'2021', end:'2024', desc:'Describe what you did here.' },
  ],
  certs: [
    { id:'seed-c1', type:'certification', name:'freeCodeCamp — Responsive Web Design', issuer:'freeCodeCamp', year:'In progress' },
    { id:'seed-c2', type:'certification', name:'Microsoft — Web Dev for Beginners', issuer:'Microsoft', year:'In progress' },
  ]
};
 
/* ═══════════════════════════════════════
   PASSWORD — change this to your own!
═══════════════════════════════════════ */
const PASSWORD = 'myportfolio123';
 
/* ═══════════════════════════════════════
   STORAGE HELPERS
═══════════════════════════════════════ */
function loadEntries() {
  try { return JSON.parse(localStorage.getItem('portfolio_entries') || '[]'); }
  catch(e) { return []; }
}
function saveEntries(arr) {
  localStorage.setItem('portfolio_entries', JSON.stringify(arr));
}
 
/* ═══════════════════════════════════════
   AUTH
═══════════════════════════════════════ */
let authed = sessionStorage.getItem('pf_auth') === '1';
 
function checkAuth() {
  const val = document.getElementById('auth-input').value;
  if (val === PASSWORD) {
    authed = true;
    sessionStorage.setItem('pf_auth','1');
    document.getElementById('auth-gate').style.display = 'none';
    document.getElementById('log-form-area').style.display = 'block';
    renderEntryList();
  } else {
    document.getElementById('auth-error').style.display = 'block';
  }
}
 
/* ═══════════════════════════════════════
   TABS
═══════════════════════════════════════ */
function switchTab(name) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-tabs button').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  document.getElementById('btn-' + name).classList.add('active');
  window.scrollTo({ top:0, behavior:'smooth' });
 
  if (name === 'logwork' && authed) {
    document.getElementById('auth-gate').style.display = 'none';
    document.getElementById('log-form-area').style.display = 'block';
    renderEntryList();
  }
}
 
/* ═══════════════════════════════════════
   FORM TYPE SWITCHING
═══════════════════════════════════════ */
let currentType = 'project';
function setType(type) {
  currentType = type;
  document.querySelectorAll('.type-tab').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
  document.querySelectorAll('.form-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('form-' + type).classList.add('active');
}
 
/* ═══════════════════════════════════════
   SAVE ENTRY
═══════════════════════════════════════ */
function saveEntry(type) {
  const entries = loadEntries();
  let entry = { id: Date.now().toString(), type };
 
  if (type === 'project') {
    const name = document.getElementById('proj-name').value.trim();
    if (!name) return alert('Please enter a project name.');
    entry.name = name;
    entry.desc = document.getElementById('proj-desc').value.trim();
    entry.url  = document.getElementById('proj-url').value.trim();
    entry.tags = document.getElementById('proj-tags').value.split(',').map(t=>t.trim()).filter(Boolean);
    // clear
    ['proj-name','proj-desc','proj-url','proj-tags'].forEach(id => document.getElementById(id).value='');
  }
  else if (type === 'skill') {
    const name = document.getElementById('skill-name').value.trim();
    if (!name) return alert('Please enter a skill name.');
    entry.name   = name;
    entry.status = document.getElementById('skill-status').value;
    document.getElementById('skill-name').value = '';
  }
  else if (type === 'experience') {
    const role = document.getElementById('exp-role').value.trim();
    if (!role) return alert('Please enter a job title.');
    entry.role    = role;
    entry.company = document.getElementById('exp-company').value.trim();
    entry.start   = document.getElementById('exp-start').value.trim();
    entry.end     = document.getElementById('exp-end').value.trim();
    entry.desc    = document.getElementById('exp-desc').value.trim();
    ['exp-role','exp-company','exp-start','exp-end','exp-desc'].forEach(id => document.getElementById(id).value='');
  }
  else if (type === 'certification') {
    const name = document.getElementById('cert-name').value.trim();
    if (!name) return alert('Please enter a certification name.');
    entry.name   = name;
    entry.issuer = document.getElementById('cert-issuer').value.trim();
    entry.year   = document.getElementById('cert-year').value.trim();
    ['cert-name','cert-issuer','cert-year'].forEach(id => document.getElementById(id).value='');
  }
 
  entries.unshift(entry);
  saveEntries(entries);
  renderAll();
  renderEntryList();
  showToast('✓ Entry saved and portfolio updated!');
}
 
/* ═══════════════════════════════════════
   DELETE ENTRY
═══════════════════════════════════════ */
function deleteEntry(id) {
  if (!confirm('Remove this entry?')) return;
  const entries = loadEntries().filter(e => e.id !== id);
  saveEntries(entries);
  renderAll();
  renderEntryList();
}
 
/* ═══════════════════════════════════════
   TOAST
═══════════════════════════════════════ */
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}
 
/* ═══════════════════════════════════════
   RENDER ALL TABS
═══════════════════════════════════════ */
function renderAll() {
  const entries  = loadEntries();
  const projects = [...SEED.projects, ...entries.filter(e=>e.type==='project')];
  const skills   = [...SEED.skills,   ...entries.filter(e=>e.type==='skill')];
  const exps     = [...SEED.experience,...entries.filter(e=>e.type==='experience')];
  const certs    = [...SEED.certs,    ...entries.filter(e=>e.type==='certification')];
 
  renderOverview(projects, skills);
  renderPortfolio(projects, exps, certs);
  renderResume(projects, skills, exps, certs);
}
 
/* ── OVERVIEW ── */
function renderOverview(projects, skills) {
  // Snaps: show up to 3 most recent projects as cards
  const snaps = document.getElementById('overview-snaps');
  const icons = ['🗂','💡','🔧','📊','🌐','⚙️'];
  snaps.innerHTML = projects.slice(0,3).map((p,i) => `
    <div class="snap-card">
      <div class="snap-icon">${icons[i % icons.length]}</div>
      <div class="snap-title">${p.name}</div>
      <div class="snap-desc">${p.desc || ''}</div>
    </div>
  `).join('');
 
  // Pills
  const pills = document.getElementById('overview-pills');
  pills.innerHTML = skills.map(s => `
    <span class="pill ${s.status==='learning'?'learning':''}">${s.name}${s.status==='learning'?' · Learning':''}</span>
  `).join('');
}
 
/* ── PORTFOLIO ── */
function renderPortfolio(projects, exps, certs) {
  // Projects
  document.getElementById('portfolio-projects').innerHTML = projects.map(p => `
    <div class="proj-card">
      <div class="proj-top">
        <span class="proj-name">${p.name}</span>
        ${p.url ? `<a href="${p.url}" class="proj-link" target="_blank">↗ GitHub</a>` : ''}
      </div>
      <p class="proj-desc">${p.desc || ''}</p>
      <div class="proj-tags">${(p.tags||[]).map(t=>`<span class="proj-tag">${t}</span>`).join('')}</div>
    </div>
  `).join('') || '<p style="color:var(--muted);font-size:14px">No projects yet — log one in the Log Work tab.</p>';
 
  // Experience timeline
  document.getElementById('portfolio-experience').innerHTML = exps.map(e => `
    <div class="tl-item">
      <div class="tl-dot"></div>
      <span class="tl-date">${e.start||''}${e.end ? ' – '+e.end : ''}</span>
      <div>
        <p class="tl-role">${e.role||e.name}</p>
        <p class="tl-company">${e.company||''}</p>
        <p class="tl-desc">${e.desc||''}</p>
      </div>
    </div>
  `).join('') || '<p style="color:var(--muted);font-size:14px">No experience yet.</p>';
 
  // Certs
  document.getElementById('portfolio-certs').innerHTML = certs.map(c => `
    <div class="cert-row">
      <span class="cert-name">${c.name}</span>
      <span class="cert-meta">${c.issuer ? c.issuer+' · ' : ''}${c.year||''}</span>
    </div>
  `).join('') || '<p style="color:var(--muted);font-size:14px">No certifications yet.</p>';
}
 
/* ── RESUME ── */
function renderResume(projects, skills, exps, certs) {
  // Skills
  document.getElementById('resume-skills').innerHTML = skills.map(s =>
    `<span class="r-skill ${s.status==='learning'?'learning':''}">${s.name}</span>`
  ).join('');
 
  // Projects
  document.getElementById('resume-projects').innerHTML = projects.map(p => `
    <div>
      <div class="r-proj-name">${p.name}${p.url ? ' — <a href="'+p.url+'" style="color:#2563eb;font-size:12px">'+p.url.replace('https://','')+'</a>' : ''}</div>
      <div class="r-proj-desc">${p.desc||''}</div>
      <div class="r-proj-tags">${(p.tags||[]).map(t=>`<span class="r-proj-tag">${t}</span>`).join('')}</div>
    </div>
  `).join('');
 
  // Experience
  document.getElementById('resume-experience').innerHTML = exps.map(e => `
    <div class="r-exp-item">
      <div class="r-exp-top">
        <span class="r-role">${e.role||e.name}</span>
        <span class="r-date">${e.start||''}${e.end ? ' – '+e.end : ''}</span>
      </div>
      <div class="r-company">${e.company||''}</div>
      ${e.desc ? `<ul class="r-bullets"><li>${e.desc}</li></ul>` : ''}
    </div>
  `).join('');
 
  // Certs
  document.getElementById('resume-certs').innerHTML = certs.map(c => `
    <div class="r-exp-top" style="margin-bottom:6px">
      <span style="font-size:13px;font-weight:600">${c.name}</span>
      <span class="r-date">${c.year||''}</span>
    </div>
  `).join('');
}
 
/* ── ENTRY LIST (Log Work tab) ── */
function renderEntryList() {
  const entries = loadEntries();
  const list = document.getElementById('entry-list');
  if (!entries.length) {
    list.innerHTML = '<div class="empty-state">No entries yet. Use the form above to add your first one.</div>';
    return;
  }
  list.innerHTML = entries.map(e => {
    let name = e.name || e.role || '—';
    let detail = e.desc || e.company || e.status || e.issuer || '';
    return `
      <div class="entry-item">
        <div class="entry-left">
          <div class="entry-type ${e.type}">${e.type}</div>
          <div class="entry-name">${name}</div>
          <div class="entry-detail">${detail}</div>
        </div>
        <div class="entry-actions">
          <button class="btn btn-danger" onclick="deleteEntry('${e.id}')">Remove</button>
        </div>
      </div>
    `;
  }).join('');
}
 
/* ═══════════════════════════════════════
   INIT
═══════════════════════════════════════ */
// If already authed this session, show form immediately
if (authed) {
  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('auth-gate').style.display = 'none';
    document.getElementById('log-form-area').style.display = 'block';
  });
}
 
renderAll();
</script>
</body>
</html>
