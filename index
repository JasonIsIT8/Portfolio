<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Jason — Portfolio</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:      #0b0d12;
      --surface: #13161f;
      --card:    #181c28;
      --border:  #242840;
      --accent:  #5b8dee;
      --accent2: #9d6eff;
      --text:    #dde1f0;
      --muted:   #6b7290;
      --green:   #3dd68c;
      --red:     #f87171;
      --tag-bg:  #0f1220;
      --radius:  10px;
    }
    html { scroll-behavior: smooth; }
    body { background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; font-size: 15px; line-height: 1.7; min-height: 100vh; }
    a { color: inherit; text-decoration: none; }
 
    /* ── NAV ── */
    nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(11,13,18,0.93);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .nav-brand { font-family:'Syne',sans-serif; font-weight:800; font-size:18px; padding:16px 0; }
    .nav-tabs { display:flex; gap:2px; list-style:none; }
    .nav-tabs button {
      background:none; border:none; cursor:pointer;
      font-family:'Inter',sans-serif; font-size:13px; font-weight:500;
      color:var(--muted); padding:20px 14px 18px;
      border-bottom:2px solid transparent;
      transition:color .2s,border-color .2s; white-space:nowrap;
    }
    .nav-tabs button:hover { color:var(--text); }
    .nav-tabs button.active { color:var(--accent); border-bottom-color:var(--accent); }
    .nav-tabs button.log-btn { color:#a78bfa; }
    .nav-tabs button.log-btn.active { color:#a78bfa; border-bottom-color:#a78bfa; }
 
    /* ── PANELS ── */
    .tab-panel { display:none; }
    .tab-panel.active { display:block; }
 
    /* ── LAYOUT ── */
    .page { max-width:820px; margin:0 auto; padding:60px 24px 100px; }
    .mono { font-family:'JetBrains Mono',monospace; font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:var(--accent); }
    .section-head { display:flex; align-items:center; gap:14px; margin-bottom:32px; }
    .section-head h2 { font-family:'Syne',sans-serif; font-size:13px; font-weight:600; text-transform:uppercase; letter-spacing:.12em; color:var(--muted); white-space:nowrap; }
    .section-head::after { content:''; flex:1; height:1px; background:var(--border); }
    section { margin-bottom:64px; }
 
    /* ── BUTTONS ── */
    .btn { display:inline-flex; align-items:center; gap:8px; padding:10px 22px; border-radius:6px; font-size:14px; font-weight:600; cursor:pointer; transition:opacity .18s,transform .18s; border:none; font-family:'Inter',sans-serif; }
    .btn:hover { opacity:.82; transform:translateY(-1px); }
    .btn-fill { background:var(--accent); color:#fff; }
    .btn-purple { background:#7c3aed; color:#fff; }
    .btn-outline { background:transparent; border:1px solid var(--border); color:var(--muted); }
    .btn-danger { background:transparent; border:1px solid var(--red); color:var(--red); font-size:12px; padding:4px 10px; border-radius:4px; }
    .btn-danger:hover { background:var(--red); color:#fff; transform:none; }
 
    /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       TAB 1 — OVERVIEW
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
    .hero { padding:72px 0 48px; }
    .hero .mono { margin-bottom:18px; }
    .hero h1 { font-family:'Syne',sans-serif; font-size:clamp(2.8rem,7vw,4.4rem); font-weight:800; line-height:1.06; margin-bottom:22px; letter-spacing:-.02em; }
    .hero h1 .grad { background:linear-gradient(100deg,var(--accent),var(--accent2)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
    .hero-sub { font-size:1.05rem; color:var(--muted); max-width:480px; margin-bottom:36px; }
    .hero-actions { display:flex; flex-wrap:wrap; gap:12px; }
 
    .status-bar { display:flex; align-items:center; gap:12px; background:var(--surface); border:1px solid var(--border); border-left:3px solid var(--green); border-radius:var(--radius); padding:16px 20px; margin-bottom:56px; }
    .pulse { width:9px; height:9px; background:var(--green); border-radius:50%; flex-shrink:0; animation:blink 2s ease-in-out infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }
    .status-bar span { font-size:14px; color:var(--muted); }
    .status-bar strong { color:var(--text); }
 
    .snap-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(210px,1fr)); gap:16px; margin-bottom:0; }
    .snap-card { background:var(--card); border:1px solid var(--border); border-radius:var(--radius); padding:24px; transition:border-color .2s; }
    .snap-card:hover { border-color:var(--accent); }
    .snap-icon { font-size:22px; margin-bottom:12px; }
    .snap-title { font-family:'Syne',sans-serif; font-weight:700; font-size:15px; margin-bottom:6px; }
    .snap-desc { font-size:13px; color:var(--muted); line-height:1.55; }
 
    .pills { display:flex; flex-wrap:wrap; gap:10px; }
    .pill { font-family:'JetBrains Mono',monospace; font-size:12px; padding:6px 14px; border-radius:4px; background:var(--tag-bg); border:1px solid var(--border); color:var(--text); }
    .pill.learning { border-color:var(--accent); color:var(--accent); }
 
    /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       TAB 2 — PORTFOLIO
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
    .proj-list { display:flex; flex-direction:column; gap:20px; }
    .proj-card { background:var(--card); border:1px solid var(--border); border-radius:var(--radius); padding:28px; transition:border-color .2s; }
    .proj-card:hover { border-color:var(--accent); }
    .proj-top { display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:10px; margin-bottom:8px; }
    .proj-name { font-family:'Syne',sans-serif; font-weight:700; font-size:17px; }
    .proj-link { font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--accent); display:inline-flex; align-items:center; gap:5px; }
    .proj-link:hover { text-decoration:underline; }
    .proj-desc { color:var(--muted); font-size:14px; margin-bottom:16px; }
    .proj-tags { display:flex; flex-wrap:wrap; gap:8px; align-items:center; }
    .proj-tag { font-size:11px; padding:3px 10px; border-radius:3px; background:var(--tag-bg); color:var(--muted); border:1px solid var(--border); }
 
    .timeline { display:flex; flex-direction:column; }
    .tl-item { display:grid; grid-template-columns:130px 1fr; gap:24px; padding-bottom:36px; position:relative; }
    .tl-item::before { content:''; position:absolute; left:130px; top:8px; bottom:0; width:1px; background:var(--border); transform:translateX(-50%); }
    .tl-item:last-child::before { display:none; }
    .tl-dot { position:absolute; left:130px; top:7px; width:9px; height:9px; border-radius:50%; background:var(--accent); border:2px solid var(--bg); transform:translateX(-50%); z-index:1; }
    @media(max-width:520px){ .tl-item{grid-template-columns:1fr;gap:4px;} .tl-item::before,.tl-dot{display:none;} }
    .tl-date { font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--muted); padding-top:5px; text-align:right; }
    .tl-role { font-family:'Syne',sans-serif; font-weight:700; font-size:16px; margin-bottom:2px; }
    .tl-company { font-size:13px; color:var(--accent); margin-bottom:8px; }
    .tl-desc { font-size:14px; color:var(--muted); }
 
    .edu-card { background:var(--card); border:1px solid var(--border); border-radius:var(--radius); padding:24px 28px; display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:12px; }
    .edu-degree { font-family:'Syne',sans-serif; font-weight:700; font-size:16px; margin-bottom:4px; }
    .edu-school { font-size:13px; color:var(--accent); }
    .edu-year { font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--muted); padding-top:4px; }
 
    .cert-list { display:flex; flex-direction:column; gap:12px; }
    .cert-row { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px; padding:16px 20px; background:var(--card); border:1px solid var(--border); border-radius:8px; }
    .cert-name { font-size:14px; font-weight:600; }
    .cert-meta { font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--muted); }
 
    /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       TAB 3 — PRINTABLE RESUME
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
    .print-wrap { max-width:760px; margin:40px auto; padding:0 24px 60px; }
    .print-actions { display:flex; justify-content:flex-end; margin-bottom:24px; }
 
    .resume-sheet { background:#fff; color:#1a1a2e; border-radius:12px; padding:52px 56px; font-family:'Inter',sans-serif; font-size:13.5px; line-height:1.6; box-shadow:0 8px 40px rgba(0,0,0,.4); }
    .r-header { margin-bottom:28px; border-bottom:2px solid #1a1a2e; padding-bottom:20px; }
    .r-name { font-family:'Syne',sans-serif; font-size:30px; font-weight:800; color:#1a1a2e; letter-spacing:-.02em; margin-bottom:6px; }
    .r-title { font-size:14px; color:#4b5563; margin-bottom:10px; }
    .r-contact { display:flex; flex-wrap:wrap; gap:6px 20px; font-size:12px; color:#4b5563; }
    .r-contact a { color:#2563eb; }
    .r-section { margin-bottom:22px; }
    .r-section-title { font-family:'Syne',sans-serif; font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:.12em; color:#2563eb; margin-bottom:10px; padding-bottom:5px; border-bottom:1px solid #e5e7eb; }
    .r-about { font-size:13px; color:#374151; }
    .r-exp-item { margin-bottom:16px; }
    .r-exp-top { display:flex; justify-content:space-between; flex-wrap:wrap; gap:4px; }
    .r-role { font-weight:700; font-size:14px; color:#1a1a2e; }
    .r-date { font-size:12px; color:#6b7280; }
    .r-company { font-size:13px; color:#2563eb; margin-bottom:5px; }
    .r-bullets { padding-left:16px; }
    .r-bullets li { font-size:13px; color:#374151; margin-bottom:3px; }
    .r-skills-row { display:flex; flex-wrap:wrap; gap:6px; }
    .r-skill { font-size:11.5px; padding:3px 10px; border-radius:3px; background:#f3f4f6; color:#374151; border:1px solid #e5e7eb; }
    .r-skill.learning { background:#eff6ff; color:#2563eb; border-color:#bfdbfe; }
    .r-projects-list { display:flex; flex-direction:column; gap:12px; }
    .r-proj-name { font-weight:700; font-size:13px; }
    .r-proj-desc { font-size:12px; color:#4b5563; }
    .r-proj-tags { display:flex; flex-wrap:wrap; gap:5px; margin-top:4px; }
    .r-proj-tag { font-size:11px; padding:2px 8px; background:#f3f4f6; border:1px solid #e5e7eb; border-radius:3px; color:#6b7280; }
 
    /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       TAB 4 — LOG WORK
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
    .log-page { max-width:640px; margin:0 auto; padding:60px 24px 100px; }
 
    .log-header { margin-bottom:48px; }
    .log-header h1 { font-family:'Syne',sans-serif; font-size:2rem; font-weight:800; margin-bottom:8px; }
    .log-header p { color:var(--muted); font-size:14px; }
 
    /* Auth gate */
    .auth-gate { background:var(--card); border:1px solid var(--border); border-radius:var(--radius); padding:40px; text-align:center; }
    .auth-gate h2 { font-family:'Syne',sans-serif; font-size:18px; margin-bottom:8px; }
    .auth-gate p { color:var(--muted); font-size:14px; margin-bottom:24px; }
    .auth-row { display:flex; gap:10px; justify-content:center; flex-wrap:wrap; }
    .auth-row input { background:var(--surface); border:1px solid var(--border); border-radius:6px; padding:10px 16px; color:var(--text); font-size:14px; width:220px; font-family:'Inter',sans-serif; }
    .auth-row input:focus { outline:none; border-color:var(--accent); }
    .auth-error { color:var(--red); font-size:13px; margin-top:12px; display:none; }
 
    /* Type selector */
    .type-tabs { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:32px; }
    .type-tab { background:var(--surface); border:1px solid var(--border); border-radius:6px; padding:8px 18px; font-size:13px; font-weight:600; color:var(--muted); cursor:pointer; transition:all .2s; }
    .type-tab:hover { border-color:var(--accent); color:var(--text); }
    .type-tab.active { background:var(--accent); border-color:var(--accent); color:#fff; }
 
    /* Form fields */
    .field { margin-bottom:20px; }
    .field label { display:block; font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:.08em; color:var(--muted); margin-bottom:8px; }
    .field input, .field textarea, .field select {
      width:100%; background:var(--surface); border:1px solid var(--border); border-radius:6px;
      padding:11px 14px; color:var(--text); font-size:14px; font-family:'Inter',sans-serif;
      transition:border-color .2s; resize:vertical;
    }
    .field input:focus, .field textarea:focus, .field select:focus { outline:none; border-color:var(--accent); }
    .field select option { background:var(--surface); }
    .field textarea { min-height:90px; }
    .field-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
    @media(max-width:500px){ .field-row{grid-template-columns:1fr;} }
 
    .form-panel { display:none; }
    .form-panel.active { display:block; }
 
    /* Success toast */
    .toast {
      position:fixed; bottom:24px; right:24px; z-index:999;
      background:#22c55e; color:#fff; padding:14px 22px; border-radius:8px;
      font-size:14px; font-weight:600; box-shadow:0 4px 20px rgba(0,0,0,.3);
      transform:translateY(80px); opacity:0; transition:all .3s;
    }
    .toast.show { transform:translateY(0); opacity:1; }
 
    /* Log entries list */
    .entries-section { margin-top:56px; }
    .entries-section h3 { font-family:'Syne',sans-serif; font-size:13px; font-weight:600; text-transform:uppercase; letter-spacing:.12em; color:var(--muted); margin-bottom:20px; display:flex; align-items:center; gap:12px; }
    .entries-section h3::after { content:''; flex:1; height:1px; background:var(--border); }
    .entry-list { display:flex; flex-direction:column; gap:12px; }
    .entry-item { background:var(--card); border:1px solid var(--border); border-radius:8px; padding:16px 20px; display:flex; justify-content:space-between; align-items:flex-start; gap:12px; }
    .entry-left { flex:1; min-width:0; }
    .entry-type { font-family:'JetBrains Mono',monospace; font-size:10px; text-transform:uppercase; letter-spacing:.1em; margin-bottom:4px; }
    .entry-type.project  { color:#60a5fa; }
    .entry-type.skill    { color:#4ade80; }
    .entry-type.experience { color:#f59e0b; }
    .entry-type.certification { color:#a78bfa; }
    .entry-name { font-weight:600; font-size:14px; margin-bottom:2px; }
    .entry-detail { font-size:13px; color:var(--muted); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .entry-actions { display:flex; gap:6px; flex-shrink:0; }
 
    /* empty state */
    .empty-state { text-align:center; padding:40px 20px; color:var(--muted); font-size:14px; border:1px dashed var(--border); border-radius:var(--radius); }
 
    /* print */
    @media print {
      nav, .print-actions { display:none !important; }
      body { background:#fff !important; }
      .tab-panel { display:block !important; }
      #tab-resume .print-wrap { margin:0; padding:0; }
      .resume-sheet { box-shadow:none; border-radius:0; padding:32px 40px; }
      * { -webkit-print-color-adjust:exact; print-color-adjust:exact; }
    }
  </style>
</head>
<body>
 
<!-- ── NAV ── -->
<nav>
  <span class="nav-brand">Jason</span>
  <ul class="nav-tabs">
    <li><button onclick="switchTab('overview')"  id="btn-overview"  class="active">Overview</button></li>
    <li><button onclick="switchTab('portfolio')" id="btn-portfolio">Portfolio</button></li>
    <li><button onclick="switchTab('resume')"    id="btn-resume">Resume</button></li>
    <li><button onclick="switchTab('logwork')"   id="btn-logwork"  class="log-btn">Log Work</button></li>
  </ul>
</nav>
 
<!-- toast -->
<div class="toast" id="toast">✓ Entry saved!</div>
 
 
