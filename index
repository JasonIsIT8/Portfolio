<!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     TAB 2 — PORTFOLIO
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
<div id="tab-portfolio" class="tab-panel">
  <div class="page">
 
    <section>
      <div class="section-head"><h2>Projects</h2></div>
      <div class="proj-list" id="portfolio-projects"><!-- dynamic --></div>
    </section>
 
    <section>
      <div class="section-head"><h2>Experience</h2></div>
